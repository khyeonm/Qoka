{
	"name": "aria-authentication",
	"displayName": "Aria Authentication",
	"description": "ORCID / Google sign-in for Aria via the Aria backend. Registers an authentication provider (Accounts menu) and stores the JWT in SecretStorage.",
	"version": "0.0.1",
	"publisher": "aria",
	"license": "MIT",
	"engines": {
		"vscode": "^1.123.0"
	},
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"authentication": [
			{
				"id": "aria",
				"label": "Aria"
			}
		],
		"commands": [
			{
				"command": "aria.auth.signIn",
				"title": "Aria: Sign In"
			},
			{
				"command": "aria.auth.signOut",
				"title": "Aria: Sign Out"
			}
		]
	},
	"scripts": {
		"compile": "node build.mjs",
		"watch": "node build.mjs --watch",
		"typecheck": "tsc -p ./ --noEmit"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^20",
		"esbuild": "^0.24.2",
		"typescript": "^5.6.2"
	}
}
