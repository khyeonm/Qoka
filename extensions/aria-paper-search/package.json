{
	"name": "aria-paper-search",
	"displayName": "Qoka Paper Library",
	"description": "Manage the user's saved-paper library. Exposes save_paper / list_saved_papers as MCP tools for Claude Code and Codex; the sidebar tab handles delete / note / tag edits locally. Built into Qoka.",
	"version": "0.0.1",
	"publisher": "aria",
	"license": "MIT",
	"engines": {
		"vscode": "^1.123.0"
	},
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished",
		"onView:aria.paperSearch.main"
	],
	"contributes": {
		"commands": [
			{
				"command": "aria.paperSearch.list",
				"title": "Qoka: List Saved Papers"
			},
			{
				"command": "aria.paperSearch.delete",
				"title": "Qoka: Delete Saved Paper"
			},
			{
				"command": "aria.paperSearch.updateNote",
				"title": "Qoka: Update Paper Note"
			},
			{
				"command": "aria.paperSearch.updateTags",
				"title": "Qoka: Update Paper Tags"
			},
			{
				"command": "aria.paperSearch.openUrl",
				"title": "Qoka: Open Paper URL"
			},
			{
				"command": "aria.paperSearch.copyToClipboard",
				"title": "Qoka: Copy to Clipboard"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^20",
		"@types/vscode": "^1.123.0",
		"typescript": "^5.6.2"
	}
}
